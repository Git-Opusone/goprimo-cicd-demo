name: CI - Build and Push Docker Image

on:
  pull_request:
    branches:
      - main

  push:
    branches:
      - main

permissions:
  contents: read
  packages: write
  security-events: write

env:
  IMAGE_NAME: goprimo-cicd-demo

jobs:
  ci:
    name: Code Quality, Test, Security, Docker Build
    runs-on: ubuntu-latest

    steps:
      - name: Checkout source code
        uses: actions/checkout@v4

      - name: Setup Node.js 20
        uses: actions/setup-node@v4
        with:
          node-version: 20
          cache: npm

      - name: Install dependencies
        run: npm ci

      - name: Run lint check
        run: npm run lint

      - name: Run unit tests
        run: npm test

      - name: Run dependency vulnerability audit
        run: npm audit --audit-level=high

      - name: Scan Dockerfile with Hadolint
        uses: hadolint/hadolint-action@v3.1.0
        with:
          dockerfile: Dockerfile
          failure-threshold: error

      - name: Build Docker image
        run: |
          docker build -t $IMAGE_NAME:ci .

      - name: Run container smoke test
        run: |
          docker run -d --name smoke-test-app -p 3000:3000 $IMAGE_NAME:ci
          sleep 5
          curl -f http://localhost:3000/health
          docker stop smoke-test-app
          docker rm smoke-test-app

      - name: Scan Docker image with Trivy
        uses: aquasecurity/trivy-action@master
        with:
          image-ref: goprimo-cicd-demo:ci
          format: table
          exit-code: 0
          severity: CRITICAL,HIGH
          ignore-unfixed: true

      - name: Convert repository owner to lowercase
        if: github.event_name == 'push'
        run: |
          echo "OWNER_LC=${GITHUB_REPOSITORY_OWNER,,}" >> $GITHUB_ENV

      - name: Login to GitHub Container Registry
        if: github.event_name == 'push'
        uses: docker/login-action@v3
        with:
          registry: ghcr.io
          username: ${{ github.actor }}
          password: ${{ secrets.GITHUB_TOKEN }}

      - name: Tag Docker image for GHCR
        if: github.event_name == 'push'
        run: |
          docker tag $IMAGE_NAME:ci ghcr.io/$OWNER_LC/$IMAGE_NAME:latest
          docker tag $IMAGE_NAME:ci ghcr.io/$OWNER_LC/$IMAGE_NAME:${{ github.sha }}

      - name: Push Docker image to GHCR
        if: github.event_name == 'push'
        run: |
          docker push ghcr.io/$OWNER_LC/$IMAGE_NAME:latest
          docker push ghcr.io/$OWNER_LC/$IMAGE_NAME:${{ github.sha }}
  deploy-prod:
    name: Deploy to Production VM
    runs-on: ubuntu-latest
    needs: ci
    if: github.event_name == 'push' && github.ref == 'refs/heads/main'

    steps:
      - name: Deploy latest image to VM over SSH
        uses: appleboy/ssh-action@v1.2.0
        with:
          host: ${{ secrets.VM_HOST }}
          username: ${{ secrets.VM_USER }}
          key: ${{ secrets.VM_SSH_KEY }}
          script: |
            set -e

            IMAGE="ghcr.io/git-opusone/goprimo-cicd-demo:latest"
            CONTAINER="goprimo-cicd-demo"

            docker network create cicd-net 2>/dev/null || true

            docker pull "$IMAGE"

            docker stop "$CONTAINER" 2>/dev/null || true
            docker rm "$CONTAINER" 2>/dev/null || true

            docker run -d \
              --name "$CONTAINER" \
              --restart unless-stopped \
              --network cicd-net \
              -e APP_ENV=prod \
              "$IMAGE"

            sleep 5
            curl -f http://goprimo-cicd-demo:3000/health || curl -f http://localhost/health

            docker image prune -f
